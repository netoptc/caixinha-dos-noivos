# Database
POSTGRES_USER=caixinha
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=caixinha_dos_noivos
DATABASE_URL="postgresql://caixinha:change_me_in_production@localhost:5431/caixinha_dos_noivos"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Platform fees (percentages, e.g. 0.05 = 5%) — kept by your platform
PLATFORM_FEE_PIX=0.05
PLATFORM_FEE_CREDIT_CARD=0.05

# Asaas gateway fees (check your account dashboard).
# Passed through to the donor so the couple receives the donated amount exact.
ASAAS_FEE_PIX=1.99
ASAAS_FEE_CARD_FIXED=0.49
ASAAS_FEE_CARD_VISTA=0.0299         # 1x
ASAAS_FEE_CARD_2_6=0.0349           # 2x to 6x
ASAAS_FEE_CARD_7_12=0.0399          # 7x to 12x

# Asaas gateway
# Use sandbox.asaas.com for testing; switch to api.asaas.com in production.
ASAAS_ENV="sandbox"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_API_KEY="your-asaas-master-api-key"
# Token used to validate inbound webhooks (configure same value in Asaas dashboard)
ASAAS_WEBHOOK_TOKEN="generate-a-random-token-here"
# All donations land in the single master account; per-couple balances and
# repasses live in the database. Anticipation is triggered on-demand by the
# couple via the dashboard (taxa Asaas descontada do valor repassado).

# SMTP (envio de e-mails transacionais)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_SECURE="true"
SMTP_USER="your-smtp-user@example.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="Caixinha dos Noivos <no-reply@example.com>"
